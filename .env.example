# ─────────────────────────────────────────────────────────────────────────────
# Zeno v5.0 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Supabase / Render / local) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/zeno

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a secure random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Pinecone Vector DB ────────────────────────────────────────────────────────
# Sign up at https://app.pinecone.io → API Keys
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=zeno
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
# Dimension MUST match your embedding model:
#   BAAI/bge-small-en-v1.5 → 384
EMBEDDING_DIMENSION=384

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── RAG Settings ─────────────────────────────────────────────────────────────
MODEL_NAME=llama-3.1-8b-instant
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
# Dev:        http://localhost:5173,http://localhost:3000
# Production: https://your-netlify-app.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── YouTube Transcript Proxy (optional — needed if YouTube blocks you) ────────
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
PROXY_URL=

# ── Supadata Fallback (optional — backup transcript source) ──────────────────
SUPADATA_API_KEY=

# ── Google OAuth (optional) ──────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
